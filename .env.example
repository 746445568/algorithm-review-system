# Backend
PORT=3001
DATABASE_URL="file:./dev.db"
SESSION_TTL_DAYS=30

# Frontend proxy target
BACKEND_ORIGIN=http://127.0.0.1:3001

# Codeforces OpenID Connect
CODEFORCES_OIDC_CLIENT_ID=
CODEFORCES_OIDC_CLIENT_SECRET=
CODEFORCES_OIDC_REDIRECT_URI=http://127.0.0.1:3000/api/auth/codeforces/callback
CODEFORCES_SYNC_MAX_PAGES=10

# Optional LLM configuration
LLM_API_KEY=
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
