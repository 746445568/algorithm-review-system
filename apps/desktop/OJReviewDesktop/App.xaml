<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="OJReviewDesktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:OJReviewDesktop.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="AppBackgroundColor">#FFFAFAFA</Color>
                    <Color x:Key="SurfaceBackgroundColor">#FFF4F4F5</Color>
                    <Color x:Key="CardBackgroundColor">#FFFFFFFF</Color>
                    <Color x:Key="BorderColor">#FFE4E4E7</Color>
                    <Color x:Key="AccentColor">#FF2563EB</Color>
                    <Color x:Key="ForegroundColor">#FF09090B</Color>
                    <Color x:Key="SecondaryForegroundColor">#FF52525B</Color>
                    <Color x:Key="MutedForegroundColor">#FF71717A</Color>
                    <Color x:Key="SuccessColor">#FF16A34A</Color>
                    <Color x:Key="WarningColor">#FFD97706</Color>
                    <Color x:Key="DangerColor">#FFDC2626</Color>
                    <Color x:Key="InfoColor">#FF2563EB</Color>
                    <Color x:Key="SkeletonBaseColor">#FFF4F4F5</Color>
                    <Color x:Key="SkeletonHighlightColor">#FFE4E4E7</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="AppBackgroundColor">#FF09090B</Color>
                    <Color x:Key="SurfaceBackgroundColor">#FF101014</Color>
                    <Color x:Key="CardBackgroundColor">#FF121215</Color>
                    <Color x:Key="BorderColor">#FF27272A</Color>
                    <Color x:Key="AccentColor">#FF3B82F6</Color>
                    <Color x:Key="ForegroundColor">#FFF4F4F5</Color>
                    <Color x:Key="SecondaryForegroundColor">#FFD4D4D8</Color>
                    <Color x:Key="MutedForegroundColor">#FFA1A1AA</Color>
                    <Color x:Key="SuccessColor">#FF4ADE80</Color>
                    <Color x:Key="WarningColor">#FFFBBF24</Color>
                    <Color x:Key="DangerColor">#FFFB7185</Color>
                    <Color x:Key="InfoColor">#FF60A5FA</Color>
                    <Color x:Key="SkeletonBaseColor">#FF17171C</Color>
                    <Color x:Key="SkeletonHighlightColor">#FF27272A</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{ThemeResource AppBackgroundColor}" />
            <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="{ThemeResource SurfaceBackgroundColor}" />
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="{ThemeResource CardBackgroundColor}" />
            <SolidColorBrush x:Key="AppBorderBrush" Color="{ThemeResource BorderColor}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{ThemeResource AccentColor}" />
            <SolidColorBrush x:Key="ForegroundBrush" Color="{ThemeResource ForegroundColor}" />
            <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="{ThemeResource SecondaryForegroundColor}" />
            <SolidColorBrush x:Key="MutedForegroundBrush" Color="{ThemeResource MutedForegroundColor}" />
            <SolidColorBrush x:Key="SuccessBrush" Color="{ThemeResource SuccessColor}" />
            <SolidColorBrush x:Key="WarningBrush" Color="{ThemeResource WarningColor}" />
            <SolidColorBrush x:Key="DangerBrush" Color="{ThemeResource DangerColor}" />
            <SolidColorBrush x:Key="InfoBrush" Color="{ThemeResource InfoColor}" />
            <SolidColorBrush x:Key="SkeletonBaseBrush" Color="{ThemeResource SkeletonBaseColor}" />
            <SolidColorBrush x:Key="SkeletonHighlightBrush" Color="{ThemeResource SkeletonHighlightColor}" />

            <FontFamily x:Key="AppChineseFontFamily">Microsoft YaHei UI</FontFamily>
            <FontFamily x:Key="AppMonoFontFamily">JetBrains Mono, Cascadia Mono, Consolas</FontFamily>

            <converters:VerdictBrushConverter x:Key="VerdictBrushConverter" />
            <converters:SyncStatusBrushConverter x:Key="SyncStatusBrushConverter" />
            <converters:StringVisibilityConverter x:Key="StringVisibilityConverter" />

            <Style TargetType="Control">
                <Setter Property="FontFamily" Value="{StaticResource AppChineseFontFamily}" />
                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            </Style>

            <Style TargetType="Page">
                <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AppChineseFontFamily}" />
                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            </Style>

            <Style x:Key="PageTitle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="32" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="CharacterSpacing" Value="-8" />
            </Style>

            <Style x:Key="PageDescription" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource SecondaryForegroundBrush}" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
                <Setter Property="LineHeight" Value="22" />
            </Style>

            <Style x:Key="SectionTitle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="CharacterSpacing" Value="-2" />
            </Style>

            <Style x:Key="MetricLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource MutedForegroundBrush}" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style x:Key="MetricValue" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AppMonoFontFamily}" />
                <Setter Property="FontSize" Value="36" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="CharacterSpacing" Value="-4" />
            </Style>

            <Style x:Key="MonoText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AppMonoFontFamily}" />
            </Style>

            <Style x:Key="AppCard" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="Padding" Value="24" />
            </Style>

            <Style x:Key="SoftPanel" TargetType="Border" BasedOn="{StaticResource AppCard}">
                <Setter Property="Background" Value="{StaticResource SurfaceBackgroundBrush}" />
            </Style>

            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="16,10" />
                <Setter Property="UseSystemFocusVisuals" Value="True" />
            </Style>

            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource SurfaceBackgroundBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="16,10" />
            </Style>

            <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource SurfaceBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="14,10" />
            </Style>

            <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
                <Setter Property="Background" Value="{StaticResource SurfaceBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="14,10" />
            </Style>

            <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
                <Setter Property="Background" Value="{StaticResource SurfaceBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="MinHeight" Value="40" />
            </Style>

            <Style x:Key="OutlinedChip" TargetType="Border">
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                <Setter Property="Background" Value="Transparent" />
            </Style>

            <Style x:Key="StatusBadge" TargetType="Border">
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="Background" Value="{StaticResource SurfaceBackgroundBrush}" />
            </Style>

            <Style x:Key="MutedCaption" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource MutedForegroundBrush}" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
            </Style>

            <Style x:Key="SkeletonBlock" TargetType="Rectangle">
                <Setter Property="Height" Value="14" />
                <Setter Property="RadiusX" Value="7" />
                <Setter Property="RadiusY" Value="7" />
                <Setter Property="Fill">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{ThemeResource SkeletonBaseColor}" Offset="0" />
                            <GradientStop Color="{ThemeResource SkeletonHighlightColor}" Offset="0.5" />
                            <GradientStop Color="{ThemeResource SkeletonBaseColor}" Offset="1" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ListView">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="IsItemClickEnabled" Value="False" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
