<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <NavigationView
            x:Name="RootNav"
            AlwaysShowHeader="False"
            CompactPaneLength="48"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="False"
            IsSettingsVisible="False"
            OpenPaneLength="220"
            PaneDisplayMode="Left"
            SelectionChanged="OnSelectionChanged">
            <NavigationView.PaneHeader>
                <Grid Height="56" Padding="12,8">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border
                            Width="36"
                            Height="36"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="10"
                            ToolTipService.ToolTip="算法复盘">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="16"
                                Foreground="White"
                                Glyph="&#xE7C3;"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="算法复盘" />
                            <TextBlock FontSize="11" Foreground="{StaticResource MutedForegroundBrush}" Text="OJ Review" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="总览" Tag="dashboard" ToolTipService.ToolTip="总览">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="账号绑定" Tag="accounts" ToolTipService.ToolTip="账号绑定">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="People" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="提交记录" Tag="submissions" ToolTipService.ToolTip="提交记录">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Document" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="题库" Tag="problems" ToolTipService.ToolTip="题库">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="ShowResults" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="错题复盘" Tag="review" ToolTipService.ToolTip="错题复盘">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Repair" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="AI 分析" Tag="analysis" ToolTipService.ToolTip="AI 分析">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9D2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="设置" Tag="settings" ToolTipService.ToolTip="设置">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Setting" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Grid Padding="24,20,24,24" RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 顶部栏：标题 + 服务状态 + 主题 -->
                <Border
                    Grid.Row="0"
                    Margin="0,0,0,16"
                    Padding="20,14"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource AppBorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="0">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                x:Name="ServiceStatusText"
                                Style="{StaticResource MutedCaption}"
                                Text="正在检查服务…" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Border
                                    Background="{Binding Text, ElementName=ServiceStatusTone, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=background}"
                                    CornerRadius="6"
                                    Padding="8,4">
                                    <TextBlock
                                        x:Name="ServiceStatusTone"
                                        FontFamily="{StaticResource AppMonoFontFamily}"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{Binding Text, ElementName=ServiceStatusTone, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=foreground}"
                                        Text="—" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <ComboBox
                            x:Name="ThemeModeBox"
                            Grid.Column="1"
                            MinWidth="140"
                            VerticalAlignment="Center"
                            SelectedIndex="0"
                            SelectionChanged="ThemeModeBox_SelectionChanged"
                            Style="{StaticResource InputComboBoxStyle}">
                            <ComboBoxItem Content="跟随系统" Tag="follow-system" />
                            <ComboBoxItem Content="浅色" Tag="light" />
                            <ComboBoxItem Content="深色" Tag="dark" />
                        </ComboBox>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="1"
                    Background="{StaticResource SurfaceBackgroundBrush}"
                    BorderBrush="{StaticResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="0">
                    <Frame x:Name="ContentFrame" />
                </Border>
            </Grid>
        </NavigationView>
    </Grid>
</Page>
