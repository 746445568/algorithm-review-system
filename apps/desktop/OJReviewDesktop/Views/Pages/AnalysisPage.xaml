<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.Pages.AnalysisPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="24" Padding="12">
            <StackPanel Spacing="6">
                <TextBlock Text="AI 分析" Style="{StaticResource PageTitle}" />
                <TextBlock Text="AI 只做增强层。配置完成后可以生成分析任务；未配置时主流程不受影响。" Style="{StaticResource PageDescription}" />
            </StackPanel>

            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.9*" />
                    <ColumnDefinition Width="1.1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="任务控制台" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="生成一次结构化分析，观察任务状态与错误信息。" Style="{StaticResource PageDescription}" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="生成分析" Style="{StaticResource PrimaryButton}" Click="GenerateButton_Click" />
                            <Button Content="刷新任务" Style="{StaticResource SecondaryButton}" Click="RefreshTaskButton_Click" />
                        </StackPanel>
                        <Border Style="{StaticResource SoftPanel}" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="任务状态" Style="{StaticResource MutedCaption}" />
                                <TextBlock x:Name="TaskMetaText" FontFamily="{StaticResource AppMonoFontFamily}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="分析结果" Style="{StaticResource SectionTitle}" />
                        <TextBox
                            x:Name="AnalysisResultBox"
                            AcceptsReturn="True"
                            IsReadOnly="True"
                            MinHeight="360"
                            Style="{StaticResource InputTextBoxStyle}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <InfoBar x:Name="StatusBar" IsOpen="False" Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>
