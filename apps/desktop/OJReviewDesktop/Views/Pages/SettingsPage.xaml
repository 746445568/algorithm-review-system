<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="24" Padding="12">
            <StackPanel Spacing="6">
                <TextBlock Text="设置" Style="{StaticResource PageTitle}" />
                <TextBlock Text="集中管理账号、AI Provider、主题和本地诊断信息。" Style="{StaticResource PageDescription}" />
            </StackPanel>

            <Grid ColumnSpacing="24" RowSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="主题" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="支持浅色、深色和跟随系统。" Style="{StaticResource PageDescription}" />
                        <ComboBox x:Name="ThemeModeBox" Header="主题模式" Style="{StaticResource InputComboBoxStyle}">
                            <ComboBoxItem Content="跟随系统" Tag="follow-system" />
                            <ComboBoxItem Content="浅色" Tag="light" />
                            <ComboBoxItem Content="深色" Tag="dark" />
                        </ComboBox>
                        <Button Content="保存主题" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Click="SaveThemeButton_Click" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="数据与诊断" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="导出非敏感诊断包，用于定位启动、迁移或同步问题。" Style="{StaticResource PageDescription}" />
                        <Button Content="导出诊断包" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Click="ExportDiagnosticsButton_Click" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="0" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="OJ 账号" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="保存公开 handle，供本地服务进行增量同步。" Style="{StaticResource PageDescription}" />
                        <TextBox x:Name="CodeforcesHandleBox" Header="Codeforces handle" PlaceholderText="tourist" Style="{StaticResource InputTextBoxStyle}" />
                        <TextBox x:Name="AtCoderHandleBox" Header="AtCoder handle" PlaceholderText="chokudai" Style="{StaticResource InputTextBoxStyle}" />
                        <Button Content="保存账号" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Click="SaveAccountsButton_Click" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="AI Provider" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="支持 OpenAI-compatible、DeepSeek-compatible 和本地 Ollama。" Style="{StaticResource PageDescription}" />
                        <ComboBox x:Name="ProviderBox" Header="Provider" SelectedIndex="0" Style="{StaticResource InputComboBoxStyle}">
                            <ComboBoxItem Content="openai-compatible" />
                            <ComboBoxItem Content="deepseek-compatible" />
                            <ComboBoxItem Content="ollama" />
                        </ComboBox>
                        <TextBox x:Name="ModelBox" Header="模型" PlaceholderText="gpt-4.1-mini" Style="{StaticResource InputTextBoxStyle}" />
                        <TextBox x:Name="BaseUrlBox" Header="Base URL" PlaceholderText="https://api.openai.com/v1" Style="{StaticResource InputTextBoxStyle}" />
                        <PasswordBox x:Name="ApiKeyBox" Header="API Key" Style="{StaticResource InputPasswordBoxStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="保存 AI 配置" Style="{StaticResource SecondaryButton}" Click="SaveAiButton_Click" />
                            <Button Content="测试连接" Style="{StaticResource PrimaryButton}" Click="TestAiButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <InfoBar x:Name="StatusBar" IsOpen="False" Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>
