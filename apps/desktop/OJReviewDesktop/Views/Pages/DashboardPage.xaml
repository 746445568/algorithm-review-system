<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OJReviewDesktop.Models">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="12" Spacing="24">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource PageTitle}" Text="总览" />
                    <TextBlock x:Name="OwnerText" Style="{StaticResource PageDescription}" />
                </StackPanel>
                <CommandBar Grid.Column="1" DefaultLabelPosition="Right">
                    <AppBarButton Click="RefreshButton_Click" Icon="Refresh" Label="刷新" />
                    <AppBarButton Click="SyncContestsButton_Click" Icon="Calendar" Label="同步比赛" />
                </CommandBar>
            </Grid>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="40" Height="40" CornerRadius="10" Background="{StaticResource AccentBrush}" Opacity="0.2">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8FD;" FontSize="18" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Style="{StaticResource MetricLabel}" Text="总提交数" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="TotalSubmissionsText" Style="{StaticResource MetricValue}" Text="0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="40" Height="40" CornerRadius="10" Background="{StaticResource SuccessBrush}" Opacity="0.2">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE73E;" FontSize="18" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Style="{StaticResource MetricLabel}" Text="通过率" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="AcRateText" Style="{StaticResource MetricValue}" Text="0%" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="40" Height="40" CornerRadius="10" Background="{StaticResource WarningBrush}" Opacity="0.2">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE734;" FontSize="18" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Style="{StaticResource MetricLabel}" Text="重复出错题" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="RepeatedFailuresText" Style="{StaticResource MetricValue}" Text="0" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel x:Name="LoadingStatePanel" Spacing="24">
                <Border Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <Rectangle Width="220" Height="20" Style="{StaticResource SkeletonBlock}" />
                        <Rectangle Height="180" Style="{StaticResource SkeletonBlock}" />
                    </StackPanel>
                </Border>
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="12">
                            <Rectangle Width="180" Height="18" Style="{StaticResource SkeletonBlock}" />
                            <Rectangle Height="220" Style="{StaticResource SkeletonBlock}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="12">
                            <Rectangle Width="180" Height="18" Style="{StaticResource SkeletonBlock}" />
                            <Rectangle Height="220" Style="{StaticResource SkeletonBlock}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <StackPanel x:Name="ContentPanel" Spacing="24" Visibility="Collapsed">
                <Border Style="{StaticResource AppCard}">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="4">
                            <TextBlock Style="{StaticResource SectionTitle}" Text="近 14 天提交趋势" />
                            <TextBlock Style="{StaticResource PageDescription}" Text="用提交节奏判断训练稳定性，观察最近是否断档。" />
                        </StackPanel>
                        <ItemsControl x:Name="SubmissionTrendItems">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:TrendPoint">
                                    <StackPanel Width="44" Margin="0,0,10,0" Spacing="8" VerticalAlignment="Bottom">
                                        <Border
                                            Height="{Binding Height}"
                                            MinHeight="10"
                                            Background="{StaticResource AccentBrush}"
                                            CornerRadius="8"
                                            VerticalAlignment="Bottom" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource MutedCaption}"
                                            Text="{Binding Label}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="0.85*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="薄弱标签" />
                                <TextBlock Style="{StaticResource PageDescription}" Text="优先观察失败频率高、通过率低的方向。" />
                            </StackPanel>

                            <ItemsControl x:Name="WeakTagChartItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:WeakTagChartPoint">
                                        <Grid Margin="0,0,0,12" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="64" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Style="{StaticResource MutedCaption}" Text="{Binding Label}" VerticalAlignment="Center" />
                                            <Border Grid.Column="1" Background="{StaticResource SurfaceBackgroundBrush}" CornerRadius="999" Height="10" VerticalAlignment="Center">
                                                <Border
                                                    Width="{Binding Width}"
                                                    HorizontalAlignment="Left"
                                                    Background="{StaticResource AccentBrush}"
                                                    CornerRadius="999" />
                                            </Border>
                                            <TextBlock
                                                Grid.Column="2"
                                                FontFamily="{StaticResource AppMonoFontFamily}"
                                                HorizontalAlignment="Right"
                                                Text="{Binding ValueText}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ListView x:Name="WeakTagsList" MaxHeight="240">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,12" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="4">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Tag}" />
                                                <TextBlock Style="{StaticResource MutedCaption}" Text="{Binding AttemptsText}" />
                                            </StackPanel>
                                            <TextBlock
                                                Grid.Column="1"
                                                FontFamily="{StaticResource AppMonoFontFamily}"
                                                Text="{Binding AcRateText}"
                                                VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="近期比赛" />
                                <TextBlock Style="{StaticResource PageDescription}" Text="只展示应用内比赛日历，不做系统提醒。" />
                            </StackPanel>
                            <ListView x:Name="UpcomingContestsList" MaxHeight="540">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Style="{StaticResource SoftPanel}">
                                            <StackPanel Spacing="8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Foreground="{StaticResource AccentBrush}" Glyph="&#xE787;" />
                                                    <TextBlock Style="{StaticResource MutedCaption}" Text="{Binding PlatformText}" />
                                                </StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="WrapWholeWords" />
                                                <TextBlock FontFamily="{StaticResource AppMonoFontFamily}" Text="{Binding StartText}" />
                                                <TextBlock Style="{StaticResource MutedCaption}" Text="{Binding DurationText}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <InfoBar x:Name="StatusBar" IsOpen="False" Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>
