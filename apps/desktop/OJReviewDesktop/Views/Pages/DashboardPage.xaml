<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OJReviewDesktop.Models">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="6">
                    <TextBlock Text="总览" Style="{StaticResource PageTitle}" />
                    <TextBlock x:Name="OwnerText" Style="{StaticResource PageDescription}" />
                </StackPanel>
                <CommandBar Grid.Column="1" DefaultLabelPosition="Right">
                    <AppBarButton Label="刷新" Icon="Refresh" Click="RefreshButton_Click" />
                    <AppBarButton Label="同步比赛" Icon="Calendar" Click="SyncContestsButton_Click" />
                </CommandBar>
            </Grid>

            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="总提交数" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="TotalSubmissionsText" Style="{StaticResource MetricValue}" Text="0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="通过率" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="AcRateText" Style="{StaticResource MetricValue}" Text="0%" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock Text="重复出错题" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="RepeatedFailuresText" Style="{StaticResource MetricValue}" Text="0" />
                </StackPanel>
            </Grid>

            <StackPanel x:Name="LoadingStatePanel" Spacing="24">
                <Border Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <Rectangle Style="{StaticResource SkeletonBlock}" Width="220" Height="22" />
                        <Rectangle Style="{StaticResource SkeletonBlock}" Height="160" />
                    </StackPanel>
                </Border>
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="12">
                            <Rectangle Style="{StaticResource SkeletonBlock}" Width="160" Height="18" />
                            <Rectangle Style="{StaticResource SkeletonBlock}" Height="180" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="12">
                            <Rectangle Style="{StaticResource SkeletonBlock}" Width="160" Height="18" />
                            <Rectangle Style="{StaticResource SkeletonBlock}" Height="180" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <StackPanel x:Name="ContentPanel" Spacing="24" Visibility="Collapsed">
                <Border Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="近 14 天提交趋势" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="用提交节奏判断训练稳定性，观察最近是否断档。" Style="{StaticResource PageDescription}" />
                        </StackPanel>
                        <ItemsControl x:Name="SubmissionTrendItems">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:TrendPoint">
                                    <StackPanel Width="42" Margin="0,0,10,0" VerticalAlignment="Bottom" Spacing="8">
                                        <Border
                                            Height="{Binding Height}"
                                            MinHeight="8"
                                            VerticalAlignment="Bottom"
                                            Background="{StaticResource AccentBrush}"
                                            CornerRadius="8" />
                                        <TextBlock Text="{Binding Label}" FontFamily="{StaticResource AppMonoFontFamily}" HorizontalAlignment="Center" Style="{StaticResource MutedCaption}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="0.8*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="薄弱标签" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="优先观察失败频率高、通过率低的方向。" Style="{StaticResource PageDescription}" />
                            </StackPanel>
                            <ItemsControl x:Name="WeakTagChartItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:WeakTagChartPoint">
                                        <Grid Margin="0,0,0,10" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="64" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Label}" VerticalAlignment="Center" Style="{StaticResource MutedCaption}" />
                                            <Border Grid.Column="1" Height="10" Background="{StaticResource SurfaceBackgroundBrush}" CornerRadius="999" VerticalAlignment="Center">
                                                <Border Width="{Binding Width}" HorizontalAlignment="Left" Background="{StaticResource AccentBrush}" CornerRadius="999" />
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding ValueText}" FontFamily="{StaticResource AppMonoFontFamily}" HorizontalAlignment="Right" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ListView x:Name="WeakTagsList" MaxHeight="220">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,12" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Tag}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding AttemptsText}" Style="{StaticResource MutedCaption}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding AcRateText}" FontFamily="{StaticResource AppMonoFontFamily}" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="近期比赛" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="只展示应用内比赛日历，不做系统提醒。" Style="{StaticResource PageDescription}" />
                            </StackPanel>
                            <ListView x:Name="UpcomingContestsList" MaxHeight="520">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Style="{StaticResource SoftPanel}" Padding="16">
                                            <StackPanel Spacing="6">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xECA7;" Foreground="{StaticResource AccentBrush}" />
                                                    <TextBlock Text="{Binding PlatformText}" Style="{StaticResource MutedCaption}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                                <TextBlock Text="{Binding StartText}" FontFamily="{StaticResource AppMonoFontFamily}" />
                                                <TextBlock Text="{Binding DurationText}" Style="{StaticResource MutedCaption}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <InfoBar x:Name="StatusBar" IsOpen="False" Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>
