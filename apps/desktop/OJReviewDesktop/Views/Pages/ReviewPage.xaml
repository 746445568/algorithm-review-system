<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.Pages.ReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OJReviewDesktop.Models">
    <ScrollViewer>
        <StackPanel Padding="12" Spacing="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource PageTitle}" Text="错题复盘" />
                    <TextBlock
                        Style="{StaticResource PageDescription}"
                        Text="按题目和按比赛两种视图查看错误模式，快速定位需要优先补强的题。" />
                </StackPanel>
                <CommandBar Grid.Column="1" DefaultLabelPosition="Right">
                    <AppBarToggleButton x:Name="ProblemViewButton" Click="ProblemViewButton_Click" IsChecked="True" Label="按题目" />
                    <AppBarToggleButton x:Name="ContestViewButton" Click="ContestViewButton_Click" Label="按比赛" />
                    <AppBarButton Click="RefreshButton_Click" Icon="Refresh" Label="刷新" />
                </CommandBar>
            </Grid>

            <StackPanel x:Name="LoadingStatePanel" Spacing="16">
                <Border Style="{StaticResource AppCard}">
                    <StackPanel Spacing="12">
                        <Rectangle Width="180" Height="18" Style="{StaticResource SkeletonBlock}" />
                        <Rectangle Height="160" Style="{StaticResource SkeletonBlock}" />
                    </StackPanel>
                </Border>
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource AppCard}">
                        <Rectangle Height="200" Style="{StaticResource SkeletonBlock}" />
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource AppCard}">
                        <Rectangle Height="200" Style="{StaticResource SkeletonBlock}" />
                    </Border>
                </Grid>
            </StackPanel>

            <StackPanel x:Name="ContentPanel" Spacing="24" Visibility="Collapsed">
                <Border x:Name="ProblemViewCard" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="按题目聚合" />
                        <ListView x:Name="ProblemSummariesList" MaxHeight="460">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ProblemSummaryItem">
                                    <Border Margin="0,0,0,12" Style="{StaticResource SoftPanel}">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="6">
                                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="WrapWholeWords" />
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <TextBlock Style="{StaticResource MutedCaption}" Text="{Binding PlatformText}" />
                                                        <TextBlock Style="{StaticResource MutedCaption}" Text="{Binding ContestText}" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <Border
                                                    Grid.Column="1"
                                                    Background="{Binding Verdict, Converter={StaticResource VerdictBrushConverter}, ConverterParameter=background}"
                                                    CornerRadius="999"
                                                    Padding="10,4">
                                                    <TextBlock
                                                        FontFamily="{StaticResource AppMonoFontFamily}"
                                                        Foreground="{Binding Verdict, Converter={StaticResource VerdictBrushConverter}, ConverterParameter=foreground}"
                                                        Text="{Binding VerdictText}" />
                                                </Border>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock FontFamily="{StaticResource AppMonoFontFamily}" Text="{Binding AttemptText}" />
                                                <TextBlock Style="{StaticResource MutedCaption}" Text="{Binding SolvedLaterText}" />
                                            </StackPanel>
                                            <TextBlock Style="{StaticResource MutedCaption}" Text="{Binding TagsText}" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border x:Name="ContestViewCard" Style="{StaticResource AppCard}" Visibility="Collapsed">
                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="按比赛聚合" />
                        <ListView x:Name="ContestGroupsList" MaxHeight="460">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ContestGroupItem">
                                    <Border Margin="0,0,0,12" Style="{StaticResource SoftPanel}">
                                        <StackPanel Spacing="8">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding ContestText}" TextWrapping="WrapWholeWords" />
                                            <TextBlock FontFamily="{StaticResource AppMonoFontFamily}" Text="{Binding MetaText}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="16">
                            <TextBlock Style="{StaticResource SectionTitle}" Text="重复出错题" />
                            <ListView x:Name="RepeatedFailuresList" MaxHeight="320">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:RepeatedFailureItem">
                                        <Grid Margin="0,0,0,12" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Title}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Grid.Column="1" FontFamily="{StaticResource AppMonoFontFamily}" Text="{Binding FailedCountText}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="16">
                            <TextBlock Style="{StaticResource SectionTitle}" Text="最近未解决" />
                            <ListView x:Name="RecentUnsolvedList" MaxHeight="320">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:RecentUnsolvedItem">
                                        <StackPanel Margin="0,0,0,12" Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="WrapWholeWords" />
                                            <TextBlock FontFamily="{StaticResource AppMonoFontFamily}" Style="{StaticResource MutedCaption}" Text="{Binding LastSubmittedText}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <InfoBar x:Name="StatusBar" IsOpen="False" Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>
