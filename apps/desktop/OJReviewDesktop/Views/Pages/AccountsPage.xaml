<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.Pages.AccountsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OJReviewDesktop.Models">
    <ScrollViewer>
        <StackPanel Padding="12" Spacing="24">
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource PageTitle}" Text="账号绑定" />
                <TextBlock
                    Style="{StaticResource PageDescription}"
                    Text="每个平台维护一个主账号。保存公开 handle 后即可触发同步，无需保存 OJ 密码。" />
            </StackPanel>

            <StackPanel x:Name="LoadingStatePanel" Spacing="24">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="14">
                            <Rectangle Width="120" Height="18" Style="{StaticResource SkeletonBlock}" />
                            <Rectangle Height="42" Style="{StaticResource SkeletonBlock}" />
                            <Rectangle Height="42" Style="{StaticResource SkeletonBlock}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="14">
                            <Rectangle Width="120" Height="18" Style="{StaticResource SkeletonBlock}" />
                            <Rectangle Height="42" Style="{StaticResource SkeletonBlock}" />
                            <Rectangle Height="42" Style="{StaticResource SkeletonBlock}" />
                        </StackPanel>
                    </Border>
                </Grid>
                <Border Style="{StaticResource AppCard}">
                    <StackPanel Spacing="12">
                        <Rectangle Width="200" Height="18" Style="{StaticResource SkeletonBlock}" />
                        <Rectangle Height="220" Style="{StaticResource SkeletonBlock}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="ContentPanel" Spacing="24" Visibility="Collapsed">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="18">
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Codeforces" />
                                <TextBlock Style="{StaticResource PageDescription}" Text="用于同步比赛、提交记录和错题数据。" />
                            </StackPanel>
                            <TextBox x:Name="CodeforcesHandleBox" Header="Handle" PlaceholderText="tourist" Style="{StaticResource InputTextBoxStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border
                                    x:Name="CodeforcesStatusBadge"
                                    HorizontalAlignment="Left"
                                    Background="{Binding Text, ElementName=CodeforcesStatusText, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=background}"
                                    Style="{StaticResource StatusBadge}">
                                    <TextBlock
                                        x:Name="CodeforcesStatusText"
                                        FontFamily="{StaticResource AppMonoFontFamily}"
                                        Foreground="{Binding Text, ElementName=CodeforcesStatusText, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=foreground}" />
                                </Border>
                                <ProgressRing x:Name="CodeforcesBusyRing" Width="18" Height="18" IsActive="False" Visibility="Collapsed" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button x:Name="SaveCodeforcesButton" Click="SaveCodeforcesButton_Click" Content="保存账号" Style="{StaticResource SecondaryButton}" />
                                <Button x:Name="SyncCodeforcesButton" Click="SyncCodeforcesButton_Click" Content="立即同步" Style="{StaticResource PrimaryButton}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="18">
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="AtCoder" />
                                <TextBlock Style="{StaticResource PageDescription}" Text="同步 AtCoder 的提交数据和比赛信息。" />
                            </StackPanel>
                            <TextBox x:Name="AtCoderHandleBox" Header="Handle" PlaceholderText="chokudai" Style="{StaticResource InputTextBoxStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border
                                    x:Name="AtCoderStatusBadge"
                                    HorizontalAlignment="Left"
                                    Background="{Binding Text, ElementName=AtCoderStatusText, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=background}"
                                    Style="{StaticResource StatusBadge}">
                                    <TextBlock
                                        x:Name="AtCoderStatusText"
                                        FontFamily="{StaticResource AppMonoFontFamily}"
                                        Foreground="{Binding Text, ElementName=AtCoderStatusText, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=foreground}" />
                                </Border>
                                <ProgressRing x:Name="AtCoderBusyRing" Width="18" Height="18" IsActive="False" Visibility="Collapsed" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button x:Name="SaveAtCoderButton" Click="SaveAtCoderButton_Click" Content="保存账号" Style="{StaticResource SecondaryButton}" />
                                <Button x:Name="SyncAtCoderButton" Click="SyncAtCoderButton_Click" Content="立即同步" Style="{StaticResource PrimaryButton}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="最近同步任务" />
                                <TextBlock Style="{StaticResource PageDescription}" Text="观察同步是否成功、拉取了多少记录、是否需要重试。" />
                            </StackPanel>
                            <Button
                                x:Name="RetryFailedButton"
                                Grid.Column="1"
                                Margin="0,0,10,0"
                                Click="RetryFailedButton_Click"
                                Content="重试失败任务"
                                IsEnabled="False"
                                Style="{StaticResource SecondaryButton}" />
                            <Button Grid.Column="2" Click="RefreshButton_Click" Content="刷新" Style="{StaticResource SecondaryButton}" />
                        </Grid>

                        <TextBlock
                            x:Name="EmptyTasksHint"
                            HorizontalAlignment="Center"
                            Style="{StaticResource MutedCaption}"
                            Text="当前还没有同步任务记录。"
                            Visibility="Collapsed" />

                        <ListView x:Name="SyncTasksList" MaxHeight="520">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:SyncTaskItem">
                                    <Border Margin="0,0,0,12" Style="{StaticResource SoftPanel}">
                                        <Grid ColumnSpacing="14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="6">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <Border
                                                        Background="{Binding Status, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=background}"
                                                        CornerRadius="999"
                                                        Padding="8,4">
                                                        <TextBlock
                                                            FontFamily="{StaticResource AppMonoFontFamily}"
                                                            Foreground="{Binding Status, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=foreground}"
                                                            Text="{Binding StatusText}" />
                                                    </Border>
                                                    <TextBlock Style="{StaticResource MutedCaption}" Text="{Binding CreatedAtText}" />
                                                </StackPanel>
                                                <TextBlock
                                                    Style="{StaticResource MutedCaption}"
                                                    Text="{Binding ErrorMessage}"
                                                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringVisibilityConverter}}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="6">
                                                <TextBlock FontFamily="{StaticResource AppMonoFontFamily}" Text="{Binding FetchedText}" />
                                                <TextBlock Style="{StaticResource MutedCaption}" Text="{Binding SavedText}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>

            <InfoBar x:Name="StatusBar" IsOpen="False" Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>
