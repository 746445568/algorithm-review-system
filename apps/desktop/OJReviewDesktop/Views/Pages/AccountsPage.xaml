<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.Pages.AccountsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OJReviewDesktop.Models">
    <ScrollViewer>
        <StackPanel Spacing="24" Padding="12">
            <StackPanel Spacing="6">
                <TextBlock Text="账号绑定" Style="{StaticResource PageTitle}" />
                <TextBlock Text="每个平台维护一个主账号。保存公开 handle 后即可触发同步，无需保存 OJ 密码。" Style="{StaticResource PageDescription}" />
            </StackPanel>

            <StackPanel x:Name="LoadingStatePanel" Spacing="24">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="14">
                            <Rectangle Style="{StaticResource SkeletonBlock}" Width="120" Height="18" />
                            <Rectangle Style="{StaticResource SkeletonBlock}" Height="42" />
                            <Rectangle Style="{StaticResource SkeletonBlock}" Height="42" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="14">
                            <Rectangle Style="{StaticResource SkeletonBlock}" Width="120" Height="18" />
                            <Rectangle Style="{StaticResource SkeletonBlock}" Height="42" />
                            <Rectangle Style="{StaticResource SkeletonBlock}" Height="42" />
                        </StackPanel>
                    </Border>
                </Grid>
                <Border Style="{StaticResource AppCard}">
                    <StackPanel Spacing="12">
                        <Rectangle Style="{StaticResource SkeletonBlock}" Width="180" Height="18" />
                        <Rectangle Style="{StaticResource SkeletonBlock}" Height="200" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="ContentPanel" Spacing="24" Visibility="Collapsed">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="18">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Codeforces" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="用于同步比赛、提交记录和错题数据。" Style="{StaticResource PageDescription}" />
                            </StackPanel>
                            <TextBox x:Name="CodeforcesHandleBox" Header="Handle" PlaceholderText="tourist" Style="{StaticResource InputTextBoxStyle}" />
                            <Border
                                x:Name="CodeforcesStatusBadge"
                                Style="{StaticResource StatusBadge}"
                                HorizontalAlignment="Left"
                                Background="{Binding Text, ElementName=CodeforcesStatusText, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=background}">
                                <TextBlock
                                    x:Name="CodeforcesStatusText"
                                    FontFamily="{StaticResource AppMonoFontFamily}"
                                    Foreground="{Binding Text, ElementName=CodeforcesStatusText, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=foreground}" />
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Content="保存账号" Style="{StaticResource SecondaryButton}" Click="SaveCodeforcesButton_Click" />
                                <Button Content="立即同步" Style="{StaticResource PrimaryButton}" Click="SyncCodeforcesButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="18">
                            <StackPanel Spacing="4">
                                <TextBlock Text="AtCoder" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="同步 AtCoder 的提交数据和比赛信息。" Style="{StaticResource PageDescription}" />
                            </StackPanel>
                            <TextBox x:Name="AtCoderHandleBox" Header="Handle" PlaceholderText="chokudai" Style="{StaticResource InputTextBoxStyle}" />
                            <Border
                                x:Name="AtCoderStatusBadge"
                                Style="{StaticResource StatusBadge}"
                                HorizontalAlignment="Left"
                                Background="{Binding Text, ElementName=AtCoderStatusText, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=background}">
                                <TextBlock
                                    x:Name="AtCoderStatusText"
                                    FontFamily="{StaticResource AppMonoFontFamily}"
                                    Foreground="{Binding Text, ElementName=AtCoderStatusText, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=foreground}" />
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Content="保存账号" Style="{StaticResource SecondaryButton}" Click="SaveAtCoderButton_Click" />
                                <Button Content="立即同步" Style="{StaticResource PrimaryButton}" Click="SyncAtCoderButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="最近同步任务" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="用于观察同步是否成功、拉取多少记录、是否需要重试。" Style="{StaticResource PageDescription}" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="刷新" Style="{StaticResource SecondaryButton}" Click="RefreshButton_Click" />
                        </Grid>

                        <ListView x:Name="SyncTasksList" MaxHeight="480">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:SyncTaskItem">
                                    <Border Margin="0,0,0,12" Style="{StaticResource SoftPanel}" Padding="16">
                                        <Grid ColumnSpacing="14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="6">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <Border
                                                        Background="{Binding Status, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=background}"
                                                        CornerRadius="999"
                                                        Padding="8,4">
                                                        <TextBlock
                                                            Text="{Binding StatusText}"
                                                            FontFamily="{StaticResource AppMonoFontFamily}"
                                                            Foreground="{Binding Status, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=foreground}" />
                                                    </Border>
                                                    <TextBlock Text="{Binding CreatedAtText}" Style="{StaticResource MutedCaption}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource MutedCaption}" Visibility="{Binding ErrorMessage, Converter={StaticResource StringVisibilityConverter}}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="6">
                                                <TextBlock Text="{Binding FetchedText}" FontFamily="{StaticResource AppMonoFontFamily}" />
                                                <TextBlock Text="{Binding SavedText}" Style="{StaticResource MutedCaption}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>

            <InfoBar x:Name="StatusBar" IsOpen="False" Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>
