<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.Pages.SubmissionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OJReviewDesktop.Models">
    <ScrollViewer>
        <StackPanel Spacing="24" Padding="12">
            <StackPanel Spacing="6">
                <TextBlock Text="提交记录" Style="{StaticResource PageTitle}" />
                <TextBlock Text="统一查看多平台提交，优先保留平台、结果、语言、耗时和比赛维度。" Style="{StaticResource PageDescription}" />
            </StackPanel>

            <Border Style="{StaticResource AppCard}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="PlatformFilterBox" Style="{StaticResource InputComboBoxStyle}">
                        <ComboBoxItem Content="全部平台" Tag="" />
                        <ComboBoxItem Content="Codeforces" Tag="CODEFORCES" />
                        <ComboBoxItem Content="AtCoder" Tag="ATCODER" />
                    </ComboBox>
                    <ComboBox Grid.Column="1" x:Name="VerdictFilterBox" Style="{StaticResource InputComboBoxStyle}">
                        <ComboBoxItem Content="全部结果" Tag="" />
                        <ComboBoxItem Content="AC" Tag="AC" />
                        <ComboBoxItem Content="WA" Tag="WA" />
                        <ComboBoxItem Content="TLE" Tag="TLE" />
                        <ComboBoxItem Content="MLE" Tag="MLE" />
                        <ComboBoxItem Content="RE" Tag="RE" />
                        <ComboBoxItem Content="CE" Tag="CE" />
                    </ComboBox>
                    <Button Grid.Column="2" Content="刷新" Style="{StaticResource SecondaryButton}" Click="RefreshButton_Click" />
                </Grid>
            </Border>

            <StackPanel x:Name="LoadingStatePanel" Spacing="16">
                <Border Style="{StaticResource AppCard}">
                    <StackPanel Spacing="12">
                        <Rectangle Style="{StaticResource SkeletonBlock}" Width="200" Height="18" />
                        <Rectangle Style="{StaticResource SkeletonBlock}" Height="72" />
                        <Rectangle Style="{StaticResource SkeletonBlock}" Height="72" />
                        <Rectangle Style="{StaticResource SkeletonBlock}" Height="72" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border x:Name="ContentCard" Style="{StaticResource AppCard}" Visibility="Collapsed">
                <ListView x:Name="SubmissionsList" MaxHeight="640">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:SubmissionItem">
                            <Border Margin="0,0,0,12" Style="{StaticResource SoftPanel}" Padding="18">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="{Binding PlatformText}" Style="{StaticResource MutedCaption}" />
                                            <TextBlock Text="{Binding ContestText}" Style="{StaticResource MutedCaption}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Language}" FontWeight="SemiBold" />
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <TextBlock Text="{Binding RuntimeText}" FontFamily="{StaticResource AppMonoFontFamily}" />
                                            <TextBlock Text="{Binding MemoryText}" FontFamily="{StaticResource AppMonoFontFamily}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="8">
                                        <Border
                                            Background="{Binding Verdict, Converter={StaticResource VerdictBrushConverter}, ConverterParameter=background}"
                                            CornerRadius="999"
                                            Padding="10,4">
                                            <TextBlock
                                                Text="{Binding VerdictText}"
                                                FontFamily="{StaticResource AppMonoFontFamily}"
                                                Foreground="{Binding Verdict, Converter={StaticResource VerdictBrushConverter}, ConverterParameter=foreground}" />
                                        </Border>
                                        <TextBlock Text="{Binding SubmittedAtText}" FontFamily="{StaticResource AppMonoFontFamily}" Style="{StaticResource MutedCaption}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <InfoBar x:Name="StatusBar" IsOpen="False" Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>
