<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <NavigationView x:ConnectionId='2'
            x:Name="RootNav"
            AlwaysShowHeader="False"
            CompactPaneLength="68"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="False"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            OpenPaneLength="68"
            PaneDisplayMode="LeftCompact"
                                                 >
            <NavigationView.PaneHeader>
                <Grid Height="64">
                    <Border
                        Width="40"
                        Height="40"
                        Margin="14,12,14,12"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="14"
                        ToolTipService.ToolTip="算法复盘平台">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="18"
                            Foreground="White"
                            Glyph="&#xE7C3;"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Tag="dashboard" ToolTipService.ToolTip="总览">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="accounts" ToolTipService.ToolTip="账号绑定">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE77B;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="submissions" ToolTipService.ToolTip="提交记录">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xF000;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="problems" ToolTipService.ToolTip="题库">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8A5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="review" ToolTipService.ToolTip="错题复盘">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE734;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="analysis" ToolTipService.ToolTip="AI 分析">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9D2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Tag="settings" ToolTipService.ToolTip="设置">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Grid Padding="28,24,28,28" RowSpacing="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource AppCard}">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource PageTitle}" Text="把多平台 OJ 提交沉淀成真正可复用的复盘资产" />
                            <TextBlock
                                Style="{StaticResource PageDescription}"
                                Text="统一同步 Codeforces、AtCoder 与手动录题数据，在一个本地工作台里完成筛选、复盘、分析与追踪。" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="10">
                            <TextBlock x:ConnectionId='4'
                                x:Name="ServiceStatusText"
                                HorizontalAlignment="Right"
                                Style="{StaticResource MutedCaption}" />
                            <Border
                                Background="{Binding Text, ElementName=ServiceStatusTone, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=background}"
                                CornerRadius="999"
                                Padding="10,4">
                                <TextBlock x:ConnectionId='6'
                                    x:Name="ServiceStatusTone"
                                    FontFamily="{StaticResource AppMonoFontFamily}"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{Binding Text, ElementName=ServiceStatusTone, Converter={StaticResource SyncStatusBrushConverter}, ConverterParameter=foreground}"
                                    Text="HEALTHY" />
                            </Border>
                            <ComboBox x:ConnectionId='5'
                                x:Name="ThemeModeBox"
                                MinWidth="156"
                                SelectedIndex="0"
                                                                                
                                Style="{StaticResource InputComboBoxStyle}">
                                <ComboBoxItem Content="跟随系统" Tag="follow-system" />
                                <ComboBoxItem Content="浅色模式" Tag="light" />
                                <ComboBoxItem Content="深色模式" Tag="dark" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="1"
                    Background="{StaticResource SurfaceBackgroundBrush}"
                    BorderBrush="{StaticResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="8">
                    <Frame x:ConnectionId='3' x:Name="ContentFrame" />
                </Border>
            </Grid>
        </NavigationView>
    </Grid>
</Page>

