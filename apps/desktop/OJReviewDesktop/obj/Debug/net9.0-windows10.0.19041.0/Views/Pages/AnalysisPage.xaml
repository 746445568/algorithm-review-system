<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.Pages.AnalysisPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="12" Spacing="24">
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource PageTitle}" Text="AI 分析" />
                <TextBlock
                    Style="{StaticResource PageDescription}"
                    Text="AI 只做增强层。配置完成后可以生成结构化分析任务；未配置时主流程不受影响。" />
            </StackPanel>

            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.9*" />
                    <ColumnDefinition Width="1.1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="任务控制台" />
                        <TextBlock Style="{StaticResource PageDescription}" Text="生成一次结构化分析，观察任务状态与错误信息。" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button x:ConnectionId='5'                              Content="生成分析" Style="{StaticResource PrimaryButton}" />
                            <Button x:ConnectionId='6'                                 Content="刷新任务" Style="{StaticResource SecondaryButton}" />
                        </StackPanel>
                        <Border Style="{StaticResource SoftPanel}">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource MutedCaption}" Text="任务状态" />
                                <TextBlock x:ConnectionId='4' x:Name="TaskMetaText" FontFamily="{StaticResource AppMonoFontFamily}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="分析结果" />
                        <TextBox x:ConnectionId='3'
                            x:Name="AnalysisResultBox"
                            AcceptsReturn="True"
                            IsReadOnly="True"
                            MinHeight="360"
                            Style="{StaticResource InputTextBoxStyle}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <InfoBar x:ConnectionId='2' x:Name="StatusBar" IsOpen="False" Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>

