<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.Pages.SubmissionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OJReviewDesktop.Models">
    <ScrollViewer>
        <StackPanel Padding="12" Spacing="24">
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource PageTitle}" Text="提交记录" />
                <TextBlock
                    Style="{StaticResource PageDescription}"
                    Text="统一查看多平台提交，保留平台、结果、语言、耗时、内存和比赛维度。" />
            </StackPanel>

            <Border Style="{StaticResource AppCard}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:ConnectionId='8' x:Name="PlatformFilterBox" Style="{StaticResource InputComboBoxStyle}">
                        <ComboBoxItem Content="全部平台" Tag="" />
                        <ComboBoxItem Content="Codeforces" Tag="CODEFORCES" />
                        <ComboBoxItem Content="AtCoder" Tag="ATCODER" />
                    </ComboBox>
                    <ComboBox x:ConnectionId='9' x:Name="VerdictFilterBox" Grid.Column="1" Style="{StaticResource InputComboBoxStyle}">
                        <ComboBoxItem Content="全部结果" Tag="" />
                        <ComboBoxItem Content="AC" Tag="AC" />
                        <ComboBoxItem Content="WA" Tag="WA" />
                        <ComboBoxItem Content="TLE" Tag="TLE" />
                        <ComboBoxItem Content="MLE" Tag="MLE" />
                        <ComboBoxItem Content="RE" Tag="RE" />
                        <ComboBoxItem Content="CE" Tag="CE" />
                    </ComboBox>
                    <Button x:ConnectionId='10' Grid.Column="2"                             Content="刷新" Style="{StaticResource SecondaryButton}" />
                </Grid>
            </Border>

            <StackPanel x:ConnectionId='2' x:Name="LoadingStatePanel" Spacing="16">
                <Border Style="{StaticResource AppCard}">
                    <StackPanel Spacing="12">
                        <Rectangle Width="200" Height="18" Style="{StaticResource SkeletonBlock}" />
                        <Rectangle Height="72" Style="{StaticResource SkeletonBlock}" />
                        <Rectangle Height="72" Style="{StaticResource SkeletonBlock}" />
                        <Rectangle Height="72" Style="{StaticResource SkeletonBlock}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border x:ConnectionId='3' x:Name="ContentCard" Style="{StaticResource AppCard}" Visibility="Collapsed">
                <ListView x:ConnectionId='5' x:Name="SubmissionsList" MaxHeight="680">
                    <ListView.ItemTemplate>
                        <DataTemplate                                   >
                            <Border Margin="0,0,0,12" Style="{StaticResource SoftPanel}">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <FontIcon Glyph="&#xE774;" />
                                            <TextBlock Style="{StaticResource MutedCaption}" Text="{Binding PlatformText}" />
                                            <FontIcon Glyph="&#xE787;" />
                                            <TextBlock Style="{StaticResource MutedCaption}" Text="{Binding ContestText}" />
                                        </StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Language}" />
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <TextBlock FontFamily="{StaticResource AppMonoFontFamily}" Text="{Binding RuntimeText}" />
                                            <TextBlock FontFamily="{StaticResource AppMonoFontFamily}" Text="{Binding MemoryText}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="8">
                                        <Border
                                            Background="{Binding Verdict, Converter={StaticResource VerdictBrushConverter}, ConverterParameter=background}"
                                            CornerRadius="999"
                                            Padding="10,4">
                                            <TextBlock
                                                FontFamily="{StaticResource AppMonoFontFamily}"
                                                Foreground="{Binding Verdict, Converter={StaticResource VerdictBrushConverter}, ConverterParameter=foreground}"
                                                Text="{Binding VerdictText}" />
                                        </Border>
                                        <TextBlock
                                            FontFamily="{StaticResource AppMonoFontFamily}"
                                            Style="{StaticResource MutedCaption}"
                                            Text="{Binding SubmittedAtText}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <InfoBar x:ConnectionId='4' x:Name="StatusBar" IsOpen="False" Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>

