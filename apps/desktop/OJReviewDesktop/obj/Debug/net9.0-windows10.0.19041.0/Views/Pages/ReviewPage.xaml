<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.Pages.ReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OJReviewDesktop.Models">
    <ScrollViewer>
        <StackPanel Spacing="24" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="6">
                    <TextBlock Text="错题复盘" Style="{StaticResource PageTitle}" />
                    <TextBlock Text="按题目和按比赛两种视图查看错误模式，快速定位需要优先补的题。" Style="{StaticResource PageDescription}" />
                </StackPanel>
                <CommandBar Grid.Column="1" DefaultLabelPosition="Right">
                    <AppBarToggleButton x:ConnectionId='19' x:Name="ProblemViewButton" Label="按题目" IsChecked="True"                                 />
                    <AppBarToggleButton x:ConnectionId='20' x:Name="ContestViewButton" Label="按比赛"                                 />
                    <AppBarButton x:ConnectionId='21' Label="刷新" Icon="Refresh"                             />
                </CommandBar>
            </Grid>

            <StackPanel x:ConnectionId='2' x:Name="LoadingStatePanel" Spacing="16">
                <Border Style="{StaticResource AppCard}">
                    <StackPanel Spacing="12">
                        <Rectangle Style="{StaticResource SkeletonBlock}" Width="180" Height="18" />
                        <Rectangle Style="{StaticResource SkeletonBlock}" Height="140" />
                    </StackPanel>
                </Border>
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource AppCard}">
                        <Rectangle Style="{StaticResource SkeletonBlock}" Height="180" />
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource AppCard}">
                        <Rectangle Style="{StaticResource SkeletonBlock}" Height="180" />
                    </Border>
                </Grid>
            </StackPanel>

            <StackPanel x:ConnectionId='3' x:Name="ContentPanel" Spacing="24" Visibility="Collapsed">
                <Border x:ConnectionId='5' x:Name="ProblemViewCard" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="按题目聚合" Style="{StaticResource SectionTitle}" />
                        <ListView x:ConnectionId='16' x:Name="ProblemSummariesList" MaxHeight="460">
                            <ListView.ItemTemplate>
                                <DataTemplate                                       >
                                    <Border Margin="0,0,0,12" Style="{StaticResource SoftPanel}" Padding="18">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding PlatformText}" Style="{StaticResource MutedCaption}" />
                                                        <TextBlock Text="{Binding ContestText}" Style="{StaticResource MutedCaption}" />
                                                    </StackPanel>
                                                </StackPanel>
                                                <Border
                                                    Grid.Column="1"
                                                    Background="{Binding LatestVerdict, Converter={StaticResource VerdictBrushConverter}, ConverterParameter=background}"
                                                    CornerRadius="999"
                                                    Padding="10,4"
                                                    VerticalAlignment="Top">
                                                    <TextBlock
                                                        Text="{Binding VerdictText}"
                                                        FontFamily="{StaticResource AppMonoFontFamily}"
                                                        Foreground="{Binding LatestVerdict, Converter={StaticResource VerdictBrushConverter}, ConverterParameter=foreground}" />
                                                </Border>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Spacing="18">
                                                <TextBlock Text="{Binding AttemptText}" FontFamily="{StaticResource AppMonoFontFamily}" />
                                                <TextBlock Text="{Binding SolvedLaterText}" Style="{StaticResource MutedCaption}" />
                                            </StackPanel>

                                            <TextBlock Text="{Binding TagsText}" Style="{StaticResource MutedCaption}" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border x:ConnectionId='6' x:Name="ContestViewCard" Style="{StaticResource AppCard}" Visibility="Collapsed">
                    <StackPanel Spacing="16">
                        <TextBlock Text="按比赛聚合" Style="{StaticResource SectionTitle}" />
                        <ListView x:ConnectionId='13' x:Name="ContestGroupsList" MaxHeight="420">
                            <ListView.ItemTemplate>
                                <DataTemplate                                     >
                                    <Border Margin="0,0,0,12" Style="{StaticResource SoftPanel}" Padding="18">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding ContestText}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="{Binding MetaText}" Style="{StaticResource MutedCaption}" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="重复出错题" Style="{StaticResource SectionTitle}" />
                            <ListView x:ConnectionId='10' x:Name="RepeatedFailuresList" MaxHeight="300">
                                <ListView.ItemTemplate>
                                    <DataTemplate                                        >
                                        <Grid Margin="0,0,0,12" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Title}" TextWrapping="WrapWholeWords" />
                                            <TextBlock Grid.Column="1" Text="{Binding FailedCountText}" FontFamily="{StaticResource AppMonoFontFamily}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AppCard}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="最近未解决" Style="{StaticResource SectionTitle}" />
                            <ListView x:ConnectionId='7' x:Name="RecentUnsolvedList" MaxHeight="300">
                                <ListView.ItemTemplate>
                                    <DataTemplate                                       >
                                        <StackPanel Margin="0,0,0,12" Spacing="4">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="{Binding LastSubmittedText}" FontFamily="{StaticResource AppMonoFontFamily}" Style="{StaticResource MutedCaption}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <InfoBar x:ConnectionId='4' x:Name="StatusBar" IsOpen="False" Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>

