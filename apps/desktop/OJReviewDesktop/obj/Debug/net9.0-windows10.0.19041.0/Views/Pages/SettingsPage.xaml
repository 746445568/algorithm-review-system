<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="12" Spacing="24">
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource PageTitle}" Text="设置" />
                <TextBlock Style="{StaticResource PageDescription}" Text="集中管理账号、AI Provider、主题和本地诊断信息。" />
            </StackPanel>

            <Grid ColumnSpacing="24" RowSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="主题" />
                        <TextBlock Style="{StaticResource PageDescription}" Text="支持浅色、深色和跟随系统。" />
                        <ComboBox x:ConnectionId='13' x:Name="ThemeModeBox" Header="主题模式" Style="{StaticResource InputComboBoxStyle}">
                            <ComboBoxItem Content="跟随系统" Tag="follow-system" />
                            <ComboBoxItem Content="浅色" Tag="light" />
                            <ComboBoxItem Content="深色" Tag="dark" />
                        </ComboBox>
                        <Button x:ConnectionId='14'                               Content="保存主题" HorizontalAlignment="Left" Style="{StaticResource SecondaryButton}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="数据与诊断" />
                        <TextBlock Style="{StaticResource PageDescription}" Text="导出非敏感诊断包，用于定位启动、迁移或同步问题。" />
                        <Button x:ConnectionId='12'                                       Content="导出诊断包" HorizontalAlignment="Left" Style="{StaticResource SecondaryButton}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="0" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="OJ 账号" />
                        <TextBlock Style="{StaticResource PageDescription}" Text="保存公开 handle，供本地服务进行增量同步。" />
                        <TextBox x:ConnectionId='9' x:Name="CodeforcesHandleBox" Header="Codeforces handle" PlaceholderText="tourist" Style="{StaticResource InputTextBoxStyle}" />
                        <TextBox x:ConnectionId='10' x:Name="AtCoderHandleBox" Header="AtCoder handle" PlaceholderText="chokudai" Style="{StaticResource InputTextBoxStyle}" />
                        <Button x:ConnectionId='11'                                  Content="保存账号" HorizontalAlignment="Left" Style="{StaticResource SecondaryButton}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AppCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="AI Provider" />
                        <TextBlock Style="{StaticResource PageDescription}" Text="支持 OpenAI-compatible、DeepSeek-compatible 和本地 Ollama。" />
                        <ComboBox x:ConnectionId='3' x:Name="ProviderBox" Header="Provider" SelectedIndex="0" Style="{StaticResource InputComboBoxStyle}">
                            <ComboBoxItem Content="openai-compatible" />
                            <ComboBoxItem Content="deepseek-compatible" />
                            <ComboBoxItem Content="ollama" />
                        </ComboBox>
                        <TextBox x:ConnectionId='4' x:Name="ModelBox" Header="模型" PlaceholderText="gpt-4.1-mini" Style="{StaticResource InputTextBoxStyle}" />
                        <TextBox x:ConnectionId='5' x:Name="BaseUrlBox" Header="Base URL" PlaceholderText="https://api.openai.com/v1" Style="{StaticResource InputTextBoxStyle}" />
                        <PasswordBox x:ConnectionId='6' x:Name="ApiKeyBox" Header="API Key" Style="{StaticResource InputPasswordBoxStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button x:ConnectionId='7'                            Content="保存 AI 配置" Style="{StaticResource SecondaryButton}" />
                            <Button x:ConnectionId='8'                            Content="测试连接" Style="{StaticResource PrimaryButton}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <InfoBar x:ConnectionId='2' x:Name="StatusBar" IsOpen="False" Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>

