<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.Pages.ProblemsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OJReviewDesktop.Models">
    <ScrollViewer>
        <StackPanel Padding="12" Spacing="24">
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource PageTitle}" Text="题库" />
                <TextBlock
                    Style="{StaticResource PageDescription}"
                    Text="统一查看归一化后的题目记录，后续的错题聚合和每日一题都会基于这里的题库。" />
            </StackPanel>

            <Border Style="{StaticResource AppCard}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:ConnectionId='8' x:Name="PlatformFilterBox" Style="{StaticResource InputComboBoxStyle}">
                        <ComboBoxItem Content="全部平台" Tag="" />
                        <ComboBoxItem Content="Codeforces" Tag="CODEFORCES" />
                        <ComboBoxItem Content="AtCoder" Tag="ATCODER" />
                    </ComboBox>
                    <TextBox x:ConnectionId='9'
                        x:Name="SearchBox"
                        Grid.Column="1"
                        PlaceholderText="搜索题目标题或关键字"
                        Style="{StaticResource InputTextBoxStyle}" />
                    <Button x:ConnectionId='10' Grid.Column="2"                             Content="刷新" Style="{StaticResource SecondaryButton}" />
                </Grid>
            </Border>

            <StackPanel x:ConnectionId='2' x:Name="LoadingStatePanel" Spacing="16">
                <Border Style="{StaticResource AppCard}">
                    <StackPanel Spacing="12">
                        <Rectangle Width="180" Height="18" Style="{StaticResource SkeletonBlock}" />
                        <Rectangle Height="92" Style="{StaticResource SkeletonBlock}" />
                        <Rectangle Height="92" Style="{StaticResource SkeletonBlock}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border x:ConnectionId='3' x:Name="ContentCard" Style="{StaticResource AppCard}" Visibility="Collapsed">
                <ListView x:ConnectionId='5' x:Name="ProblemsList" MaxHeight="660">
                    <ListView.ItemTemplate>
                        <DataTemplate                                >
                            <Border Margin="0,0,0,12" Style="{StaticResource SoftPanel}">
                                <StackPanel Spacing="12">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="6">
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="WrapWholeWords" />
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <FontIcon Glyph="&#xE774;" />
                                                <TextBlock Style="{StaticResource MutedCaption}" Text="{Binding PlatformText}" />
                                                <FontIcon Glyph="&#xE787;" />
                                                <TextBlock Style="{StaticResource MutedCaption}" Text="{Binding ContestText}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <Border Grid.Column="1" Style="{StaticResource StatusBadge}">
                                            <TextBlock FontFamily="{StaticResource AppMonoFontFamily}" Text="{Binding DifficultyText}" />
                                        </Border>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Foreground="{StaticResource AccentBrush}" Glyph="&#xE8FD;" />
                                        <TextBlock Style="{StaticResource MutedCaption}" Text="{Binding TagsText}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>

                                    <TextBlock Foreground="{StaticResource AccentBrush}" Text="{Binding Url}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <InfoBar x:ConnectionId='4' x:Name="StatusBar" IsOpen="False" Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>

