<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="OJReviewDesktop.Views.Pages.ProblemsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OJReviewDesktop.Models">
    <ScrollViewer>
        <StackPanel Spacing="24" Padding="12">
            <StackPanel Spacing="6">
                <TextBlock Text="题库" Style="{StaticResource PageTitle}" />
                <TextBlock Text="统一查看归一化后的题目记录，后续的错题聚合和每日一题都基于这里的题库。" Style="{StaticResource PageDescription}" />
            </StackPanel>

            <Border Style="{StaticResource AppCard}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:ConnectionId='8' x:Name="PlatformFilterBox" Style="{StaticResource InputComboBoxStyle}">
                        <ComboBoxItem Content="全部平台" Tag="" />
                        <ComboBoxItem Content="Codeforces" Tag="CODEFORCES" />
                        <ComboBoxItem Content="AtCoder" Tag="ATCODER" />
                    </ComboBox>
                    <TextBox x:ConnectionId='9' Grid.Column="1" x:Name="SearchBox" Style="{StaticResource InputTextBoxStyle}" PlaceholderText="搜索题目标题或关键字" />
                    <Button x:ConnectionId='10' Grid.Column="2" Content="刷新" Style="{StaticResource SecondaryButton}"                             />
                </Grid>
            </Border>

            <StackPanel x:ConnectionId='2' x:Name="LoadingStatePanel" Spacing="16">
                <Border Style="{StaticResource AppCard}">
                    <StackPanel Spacing="12">
                        <Rectangle Style="{StaticResource SkeletonBlock}" Width="180" Height="18" />
                        <Rectangle Style="{StaticResource SkeletonBlock}" Height="92" />
                        <Rectangle Style="{StaticResource SkeletonBlock}" Height="92" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border x:ConnectionId='3' x:Name="ContentCard" Style="{StaticResource AppCard}" Visibility="Collapsed">
                <ListView x:ConnectionId='5' x:Name="ProblemsList" MaxHeight="620">
                    <ListView.ItemTemplate>
                        <DataTemplate                                >
                            <Border Margin="0,0,0,12" Style="{StaticResource SoftPanel}" Padding="18">
                                <StackPanel Spacing="10">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="{Binding PlatformText}" Style="{StaticResource MutedCaption}" />
                                                <TextBlock Text="{Binding ContestText}" Style="{StaticResource MutedCaption}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <Border Grid.Column="1" Style="{StaticResource StatusBadge}" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Difficulty}" FontFamily="{StaticResource AppMonoFontFamily}" />
                                        </Border>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8FD;" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="{Binding TagsText}" Style="{StaticResource MutedCaption}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>

                                    <TextBlock Text="{Binding Url}" Foreground="{StaticResource AccentBrush}" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <InfoBar x:ConnectionId='4' x:Name="StatusBar" IsOpen="False" Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>

