{
  "name": "ojreview-desktop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": "OJ Review Team",
  "description": "Electron desktop shell for OJ Review",
  "main": "main/index.mjs",
  "build": {
    "appId": "com.ojreview.desktop",
    "productName": "OJReviewDesktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "preload/**/*",
      "bootstrap/**/*",
      "renderer/dist/**/*",
      "bin/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "bin/**/*"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": "**/*"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "746445568",
      "repo": "algorithm-review-system"
    },
    "artifactName": "OJReviewDesktop-${version}-${os}-${arch}.${ext}"
  },
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:renderer": "vite --config ./renderer/vite.config.mjs",
    "start": "node ./scripts/start-static.mjs",
    "start:static": "node ./scripts/start-static.mjs",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build renderer",
    "build:electron": "node ./scripts/build.mjs",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "idb": "^8.0.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^37.2.6",
    "electron-builder": "^25.0.0",
    "vite": "^7.1.3"
  }
}
